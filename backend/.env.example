JWT_SECRET=your-secret-key-change-this
PORT=3001
# Публичный URL фронтенда — в ссылке сброса пароля (без слэша в конце)
FRONTEND_URL=http://localhost:5173

# Отправка писем (сброс пароля). Без этого в production вернётся ошибка 503.
# Примеры: Gmail — smtp.gmail.com:587 + пароль приложения; Yandex — smtp.yandex.ru:465 + SMTP_SECURE=true
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
# От кого письмо (должен быть разрешён провайдером). По умолчанию — SMTP_USER
# SMTP_FROM="Портфель <noreply@example.com>"
# Для порта 465 обычно нужно SMTP_SECURE=true
# SMTP_SECURE=false
